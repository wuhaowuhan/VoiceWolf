<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="30dp"
    app:cardElevation="4dp">

    <FrameLayout
        android:layout_width="60dp"
        android:layout_height="60dp">

        <!-- Player avatar/background -->
        <ImageView
            android:id="@+id/playerAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/player_avatar" />

        <!-- Player number overlay -->
        <TextView
            android:id="@+id/playerNumber"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/player_background"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Status indicator (dead/alive) -->
        <View
            android:id="@+id/statusIndicator"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="4dp"
            android:background="@drawable/status_indicator_alive" />

        <!-- Role badge indicator -->
        <View
            android:id="@+id/roleBadge"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="bottom|start"
            android:layout_margin="4dp"
            android:background="@drawable/status_indicator_alive"
            android:visibility="gone" />
        
        <!-- Role text -->
        <TextView
            android:id="@+id/roleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="8sp"
            android:textStyle="bold"
            android:visibility="visible" />
    </FrameLayout>
</androidx.cardview.widget.CardView>
