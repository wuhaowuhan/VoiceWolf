<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".MainActivity">

    <!-- Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/info_panel"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/roundText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="轮次: 1"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="菜单"
            android:src="@android:drawable/ic_menu_more"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Main Content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomControl"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <!-- Left Column Players (1-6) -->
        <LinearLayout
            android:id="@+id/leftColumn"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <include
                android:id="@+id/player1"
                layout="@layout/item_player"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="4dp" />

            <include
                android:id="@+id/player2"
                layout="@layout/item_player"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="4dp" />

            <include
                android:id="@+id/player3"
                layout="@layout/item_player"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="4dp" />

            <include
                android:id="@+id/player4"
                layout="@layout/item_player"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="4dp" />

            <include
                android:id="@+id/player5"
                layout="@layout/item_player"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="4dp" />

            <include
                android:id="@+id/player6"
                layout="@layout/item_player"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="4dp" />
        </LinearLayout>

        <!-- Right Column Players (7-12) -->
        <LinearLayout
            android:id="@+id/rightColumn"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <include
                android:id="@+id/player7"
                layout="@layout/item_player"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="4dp" />

            <include
                android:id="@+id/player8"
                layout="@layout/item_player"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="4dp" />

            <include
                android:id="@+id/player9"
                layout="@layout/item_player"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="4dp" />

            <include
                android:id="@+id/player10"
                layout="@layout/item_player"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="4dp" />

            <include
                android:id="@+id/player11"
                layout="@layout/item_player"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="4dp" />

            <include
                android:id="@+id/player12"
                layout="@layout/item_player"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="4dp" />
        </LinearLayout>

        <!-- Center Panel - Speech and Vote Records -->
        <androidx.cardview.widget.CardView
            android:id="@+id/centerPanel"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="8dp"
            app:cardBackgroundColor="@color/info_panel"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/rightColumn"
            app:layout_constraintStart_toEndOf="@id/leftColumn"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Speech Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝 本轮发言"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="4dp"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/speechInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="暂无发言记录"
                        android:textColor="@color/gray_light"
                        android:textSize="13sp" />
                </ScrollView>

                <!-- Vote Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="🗳️ 本轮投票"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="4dp"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/voteInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="暂无投票记录"
                        android:textColor="@color/gray_light"
                        android:textSize="13sp" />
                </ScrollView>

                <!-- Vote Statistics -->
                <TextView
                    android:id="@+id/voteStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/teal_200"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Control Panel -->
    <LinearLayout
        android:id="@+id/bottomControl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/info_panel"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddSpeech"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="+ 记录发言"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddVote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="+ 记录投票"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="历史"
            android:textSize="13sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>